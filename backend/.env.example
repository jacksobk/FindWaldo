# ───────────────────────────────────────────────────────────────────────
# Multimodal Visual Search — Backend Configuration
#
# Copy to backend/.env and fill in the three secrets (ES_URL, ES_API_KEY,
# JINA_API_KEY). Everything else has a sensible default.
# ───────────────────────────────────────────────────────────────────────

# --- Elasticsearch (9.x with Elastic Inference Service) ----------------
# Cloud:        https://cloud.elastic.co  →  deployment  →  "Endpoints" tab
# Self-managed: typically https://localhost:9200
ES_URL=https://your-cluster.es.us-central1.gcp.cloud.es.io:443
ES_API_KEY=replace-with-your-base64-encoded-api-key
ES_VERIFY_CERTS=true

# --- Inference endpoint -------------------------------------------------
# The name of the EIS inference endpoint provisioned in Kibana (see
# docs/elasticsearch-setup.md). Used for text-query embedding via
# query_vector_builder, and attempted first for image embedding.
INFERENCE_ID=jinaai-multimodal
EIS_MODEL_ID=jina-clip-v2

# --- Jina AI API key ----------------------------------------------------
# Required for: (1) the reranker (jina-reranker-m0), and (2) the image-
# embedding fallback used when the EIS endpoint is provisioned text-only
# and rejects image input. See docs/engineering-notes.md for why.
# Get a key at https://jina.ai
JINA_API_KEY=replace-with-your-jina-api-key
JINA_MODEL_ID=jina-clip-v2

# --- Index --------------------------------------------------------------
INDEX_NAME=wheres-waldo-tiles
EMBEDDING_DIMS=1024

# --- Tiling -------------------------------------------------------------
TILE_SIZE=384
TILE_OVERLAP=0.33
MAX_IMAGE_DIM=3072
EMBEDDING_BATCH_SIZE=16

# --- Reranker -----------------------------------------------------------
RERANKER_ENABLED=true
RERANKER_CANDIDATES=20

# --- Relevance thresholds (see docs/relevance-tuning.md) ----------------
# Relative within-query filter: keep hits within this fraction of top score.
SCORE_THRESHOLD_RATIO=0.80
# Per-hit absolute floor (defensive noise gate). 0.0 disables.
MIN_ABSOLUTE_SCORE=0.55
# Top-1 hard floor: return zero hits if the best match is below this.
# Primary absent-target rejection mechanism. 0.0 disables.
MIN_TOP_SCORE_TO_RETURN=0.75

# --- Query expansion ----------------------------------------------------
QUERY_EXPANSION_ENABLED=false
QUERY_EXPANSION_STRATEGY=rule
QUERY_EXPANSION_MAX_VARIANTS=4

# --- Reference targets (prototype subsystem; off by default) ------------
# See docs/engineering-notes.md — works for visually distinctive subjects,
# hurt precision on near-identical decoys with the small crop set here.
REFERENCE_TARGETS_ENABLED=false
REFERENCE_TARGETS_MANIFEST=./reference_targets/manifest.json
REFERENCE_TARGETS_DIR=./reference_targets

# --- Server -------------------------------------------------------------
STATIC_DIR=./static
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8280
